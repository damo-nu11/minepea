# PEA — integration switches. ALL OPTIONAL: with none set, the app runs
# fully locally on the mock engine + wallet stub.
#
# Contract addresses do NOT live here — lib/contracts.ts is the single
# source of truth for chain + contracts.

# Privy dashboard app id → real wallet connect replaces the stub.
NEXT_PUBLIC_PRIVY_APP_ID=

# Game backend base URL → ApiGameStore (REST + SSE) replaces the mock engine.
# Live backend: https://api.minepea.com (contract: backend/API.md +
# FRONTEND_INTEGRATION_MAP.md).
NEXT_PUBLIC_API_URL=

# OPTIONAL Robinhood Chain RPC override (e.g. a dedicated keyed endpoint).
# Unset → the public RPC baked into lib/contracts.ts.
NEXT_PUBLIC_RPC_URL=
